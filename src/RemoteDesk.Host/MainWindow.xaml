<Window x:Class="RemoteDesk.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Visibility="Hidden"
        ShowInTaskbar="False"
        WindowStyle="None"
        Width="0" Height="0">

    <tb:TaskbarIcon x:Name="TrayIcon"
                    IconSource="/Resources/tray.ico"
                    ToolTipText="RemoteDesk"
                    DoubleClickCommand="{x:Static local:MainWindow.OpenSettingsCommand}"
                    xmlns:local="clr-namespace:RemoteDesk.Host">
        <tb:TaskbarIcon.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Einstellungen" Click="OnSettingsClick"/>
                <Separator/>
                <MenuItem Header="Beenden" Click="OnExitClick"/>
            </ContextMenu>
        </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>
</Window>
